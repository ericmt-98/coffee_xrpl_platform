# Xaman Developer Console credentials
# Register your app at https://apps.xaman.dev to get these.
# NEVER commit the real .env — only this .env.example goes to the repo.
XUMM_APIKEY=your-api-key-here
XUMM_APISECRET=your-api-secret-here

# Backend database (SQLite path relative to backend/)
DATABASE_URL=sqlite:///./backend.db
